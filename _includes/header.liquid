<!-- Wrapper -->
<div id="wrapper">

  {%- capture grouped_nav_links -%}
    {%- for page in site.pages -%}
      {%- if page.group == true -%}
        <li>
          <a href="{{ page.url | relative_url }}">{{ page.title }}</a>
        </li>
      {%- endif -%}
    {%- endfor -%}
  {%- endcapture -%}
  {%- assign grouped_nav_links = grouped_nav_links | strip -%}

  {%- capture external_nav_links -%}
    {%- if site.extern_urls -%}
      {%- for url in site.extern_urls -%}
        <li>
          <a href="{{ url[1] }}">{{ url[0] }}</a>
        </li>
      {%- endfor -%}
    {%- endif -%}
  {%- endcapture -%}
  {%- assign external_nav_links = external_nav_links | strip -%}

  {%- assign contact_page_title = 'Contact' -%}

  <!-- Header -->
  <header 
    id="header" 
    style="
      border-bottom-left-radius: 20px;
      border-bottom-right-radius: 20px;
      " 
    {%- if page.layout == "home" -%} 
      class="alt" 
    {%- endif -%}
  >
    <a href="{{ '/' | relative_url }}" class="logo" target="_self">
      <strong>{{ site.title }}</strong>
    </a>
    <nav>
      <ul class="site-nav-links" aria-label="Primary">
        {% if site.group_pages != true %}
          {%- for page in site.pages -%}
            {%- if page.layout != "home" and page.nav-menu == true and page.title == contact_page_title -%}
              <li>
                <a href="{{ page.url | relative_url }}">{{ page.title }}</a>
              </li>
            {%- endif -%}
          {%- endfor -%}
          {%- for page in site.pages -%}
            {%- if page.layout != "home" and page.nav-menu == true and page.title != contact_page_title -%}
              <li>
                <a href="{{ page.url | relative_url }}">{{ page.title }}</a>
              </li>
            {%- endif -%}
          {%- endfor -%}
        {% endif %}

        {% if site.group_pages == true %}
          {%- for page in site.pages -%}
            {%- if page.layout != "home" and page.nav-menu == true and page.group != true and page.title == contact_page_title -%}
              <li>
                <a href="{{ page.url | relative_url }}">{{ page.title }}</a>
              </li>
            {%- endif -%}
          {%- endfor -%}
          {%- for page in site.pages -%}
            {%- if page.layout != "home" and page.nav-menu == true and page.group != true and page.title != contact_page_title -%}
              <li>
                <a href="{{ page.url | relative_url }}">{{ page.title }}</a>
              </li>
            {%- endif -%}
          {%- endfor -%}

          {%- if grouped_nav_links != "" -%}
            <li class="nav-dropdown">
                <button
                  type="button"
                  class="nav-dropdown-trigger"
                  aria-expanded="false"
                  aria-controls="header-projects-dropdown">
                  <span class="nav-dropdown-label">{{ site.group_name }}</span>
                  <span class="nav-dropdown-caret" aria-hidden="true"></span>
                </button>
                <ul class="nav-dropdown-panel" id="header-projects-dropdown">
                  {{ grouped_nav_links }}
                </ul>
            </li>
          {%- endif -%}
        {% endif %}

        {%- if external_nav_links != "" -%}
          <li class="nav-dropdown">
              <button
                type="button"
                class="nav-dropdown-trigger"
                aria-expanded="false"
                aria-controls="header-external-dropdown">
                <span class="nav-dropdown-label">{{ site.extern_name }}</span>
                <span class="nav-dropdown-caret" aria-hidden="true"></span>
              </button>
              <ul class="nav-dropdown-panel" id="header-external-dropdown">
                {{ external_nav_links }}
              </ul>
          </li>
        {%- endif -%}
      </ul>

      <div class="site-search-shell">
        <a
          href="{{ '/search' | relative_url }}"
          class="icon fa fa-search site-search-toggle"
          data-search-toggle="true"
          aria-controls="site-search-form"
          aria-expanded="false"
          aria-label="Open site search"></a>
        <form action="{{ '/search' | relative_url }}" class="site-search-form" id="site-search-form" method="get" role="search">
          <label class="visually-hidden" for="site-search-input">Search the site</label>
          <input
            type="text"
            id="site-search-input"
            name="q"
            maxlength="255"
            placeholder="Search posts, projects, and pages"
            autocomplete="off" />
          <button type="submit" class="button small">Search</button>
        </form>
      </div>
      <a href="#menu" class="site-menu-toggle" aria-label="Open site menu"></a>
    </nav>
  </header>

  <!-- Menu -->
  <nav id="menu">
    <ul class="links">
      <!-- find the home page and add it first -->
      {%- for page in site.pages -%}
        {%- if page.layout == "home" -%}
          <li>
            <a href="{{ '/' | relative_url }}">{{ page.title }}</a>
          </li>
          {% break %}
        {%- endif -%}
      {%- endfor -%}

      <!-- when groups are disabled -->
      {% if site.group_pages != true %}
      {%- for page in site.pages -%}
        {%- if page.layout != "home" and page.nav-menu == true and page.title == contact_page_title -%}
          <li>
            <a href="{{ page.url | relative_url }}">{{ page.title }}</a>
          </li>
        {%- endif -%}
      {%- endfor -%}
      {%- for page in site.pages -%}
        {%- if page.layout != "home" and page.nav-menu == true and page.title != contact_page_title -%}
          <li>
            <a href="{{ page.url | relative_url }}">{{ page.title }}</a>
          </li>
        {%- endif -%}
      {%- endfor -%}
      {% endif %}

      <!-- when groups are enabled -->
      <!-- add links not part of group -->
      {% if site.group_pages == true %}
      {%- for page in site.pages -%}
        {%- if page.layout != "home" and page.nav-menu == true and page.group != true and page.title == contact_page_title -%}
          <li>
            <a href="{{ page.url | relative_url }}">{{ page.title }}</a>
          </li>
        {%- endif -%}
      {%- endfor -%}
      {%- for page in site.pages -%}
        {%- if page.layout != "home" and page.nav-menu == true and page.group != true and page.title != contact_page_title -%}
          <li>
            <a href="{{ page.url | relative_url }}">{{ page.title }}</a>
          </li>
        {%- endif -%}
      {%- endfor -%}
      
      <!-- add group -->
      <br>
      <button class="col_head fit">{{ site.group_name }}</button>
      <div class="col_con">
        <ul class="links">
          {%- for page in site.pages -%}
            <!-- assume all pages with group = true also have nav-menu = true -->
            {%- if page.group == true -%}
              <li>
                <a href="{{ page.url | relative_url }}">{{ page.title }}</a>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      </div>
      {% endif %}
      
      <!-- add external urls if any -->
      {% if site.extern_urls %}
          <br>
          <button class="col_head fit special">{{ site.extern_name }}</button>
          <div class="col_con">
            <ul class="links">
              {% for url in site.extern_urls %} 
              <li>
                <a href="{{ url[1] }}">{{ url[0] }}</a>
              </li>
            
              {% endfor %}
            </ul>
          </div>            
      {% endif %}
      
    </ul>
  </nav>
