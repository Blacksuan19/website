<script src="/assets/js/lunr.js"></script>

<script>
  {%- assign counter = 0 -%}
  {% assign allPages = site.pages | concat: site.posts %}
  var documents = [
    {% for page in allPages %}
      {%- if page.url contains '.xml' or page.url contains 'assets' or page.title == "Home" or page.title == 404 -%}
        {%- else -%}{
        "id": {{ counter }},
        "url": "{{ page.url | relative_url }}",
        "description": "{{ page.description }}",
        "title": "{{ page.title }}",
        "image": "{{ page.image | default: '/assets/images/logo.jpg' | relative_url }}",
        "body": "{{ page.content | markdownify | replace: '.', '. ' | replace: '</h2>', ': ' | replace: '</h3>', ': ' | replace: '</h4>', ': ' | replace: '</p>', ' ' | strip_html | strip_newlines | replace: '  ', ' ' | replace: '"', ' ' }}"
        {%- assign counter = counter | plus: 1 -%}
        },
      {%- endif -%}
    {% endfor %}
  ];

  var idx = lunr(function () {
      this.ref('id')
      this.field('title')
      this.field('body')

      documents.forEach(function (doc) {
          this.add(doc)
      }, this)
  });
  function escapeHtml(value) {
    return value.replace(/[&<>"']/g, function (character) {
      return {
        '&': '&amp;',
        '<': '&lt;',
        '>': '&gt;',
        '"': '&quot;',
        "'": '&#39;'
      }[character];
    });
  }

  function getQueryFromUrl() {
    return new URLSearchParams(window.location.search).get('q') || '';
  }

  function updateQueryInUrl(query) {
    var url = new URL(window.location.href);

    if (query) {
      url.searchParams.set('q', query);
    } else {
      url.searchParams.delete('q');
    }

    window.history.replaceState({}, '', url.toString());
  }

  function buildTileMarkup(documentItem) {
    var safeUrl = escapeHtml(documentItem.url);
    var safeTitle = escapeHtml(documentItem.title);
    var safeImage = escapeHtml(documentItem.image);

    return `
      <article>
        <span class="image">
          <img src="${safeImage}" alt="${safeTitle}" />
        </span>
        <a href="${safeUrl}" class="link primary" aria-label="${safeTitle}"></a>
        <header class="major">
          <h4>
            <a href="${safeUrl}" class="link">${safeTitle}</a>
          </h4>
        </header>
      </article>
    `;
  }

  function renderIdleState() {
    document.getElementById('search-feedback').innerHTML = `
      <p class="search-page__status-copy">Search titles and page content from across the site.</p>
    `;
    document.getElementById('lunrsearchresults').innerHTML = '';
  }

  function renderNoResults(query) {
    document.getElementById('search-feedback').innerHTML = `
      <p class="search-page__status-copy">No results for <strong>“${escapeHtml(query)}”</strong>. Try a broader keyword or related term.</p>
    `;
    document.getElementById('lunrsearchresults').innerHTML = '<p class="search-page__empty">No matching posts or pages were found.</p>';
  }

  function renderResults(query, results) {
    var markup = '<section class="tiles" id="one">';

    for (var i = 0; i < results.length; i++) {
      markup += buildTileMarkup(documents[results[i].ref]);
    }

    markup += '</section>';

    document.getElementById('search-feedback').innerHTML = `
      <p class="search-page__status-copy"><strong>${results.length}</strong> result${results.length === 1 ? '' : 's'} for <strong>“${escapeHtml(query)}”</strong></p>
    `;
    document.getElementById('lunrsearchresults').innerHTML = markup;
  }

  function lunr_search(rawTerm) {
      var term = rawTerm.trim();

      updateQueryInUrl(term);

      if (!term) {
          renderIdleState();
          return false;
      }

      var results = idx.search(term);

      if (results.length > 0) {
          renderResults(term, results);
      } else {
          renderNoResults(term);
      }

      return false;
  }

  document.addEventListener('DOMContentLoaded', function () {
    var input = document.getElementById('lunrsearch');
    var initialQuery = getQueryFromUrl().trim();

    if (initialQuery) {
      input.value = initialQuery;
      lunr_search(initialQuery);
    } else {
      renderIdleState();
    }

    document.getElementById('search-clear').addEventListener('click', function () {
      input.value = '';
      input.focus();
      lunr_search('');
    });
  });
</script>

<section class="search-page" aria-label="Site search">
  <form class="search-page__form" onSubmit="return lunr_search(document.getElementById('lunrsearch').value);" role="search">
    <label class="visually-hidden" for="lunrsearch">Search query</label>
    <div class="search-page__controls">
      <input
        type="text"
        class="form-control search-page__input"
        id="lunrsearch"
        name="q"
        maxlength="255"
        value=""
        placeholder="Search by topic, tool, or post title"
      />
      <button type="submit" class="button special">Search</button>
      <button type="button" class="button" id="search-clear">Clear</button>
    </div>
  </form>

  <div id="search-feedback" class="search-page__status" aria-live="polite"></div>
  <div id="lunrsearchresults" class="search-page__results"></div>
</section>
