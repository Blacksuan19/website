{%- assign image = site.data.optimized_images[include.path] -%}
{%- assign image_alt = include.alt | default: '' -%}
{%- assign image_sizes = include.sizes | default: '100vw' -%}
{%- assign image_loading = include.loading | default: 'lazy' -%}
{%- assign image_decoding = include.decoding | default: 'async' -%}
{%- assign image_fetchpriority = include.fetchpriority | default: nil -%}
{%- assign image_class = include.class | default: nil -%}
{%- assign image_picture_class = include.picture_class | default: nil -%}

{%- if image and image.type == 'raster' and image.variants and image.variants != empty -%}
  <picture{% if image_picture_class %} class="{{ image_picture_class }}"{% endif %}>
    <source
      type="image/webp"
      srcset="{%- for variant in image.variants -%}{{ variant.path }} {{ variant.width }}w{% unless forloop.last %}, {% endunless %}{%- endfor -%}"
      sizes="{{ image_sizes }}">
    <img
      src="{{ include.path }}"
      alt="{{ image_alt }}"
      {% if image_class %}class="{{ image_class }}"{% endif %}
      width="{{ image.width }}"
      height="{{ image.height }}"
      loading="{{ image_loading }}"
      decoding="{{ image_decoding }}"
      {% if image_fetchpriority %}fetchpriority="{{ image_fetchpriority }}"{% endif %}>
  </picture>
{%- else -%}
  <img
    src="{{ include.path }}"
    alt="{{ image_alt }}"
    {% if image_class %}class="{{ image_class }}"{% endif %}
    {% if image and image.width %}width="{{ image.width }}"{% endif %}
    {% if image and image.height %}height="{{ image.height }}"{% endif %}
    loading="{{ image_loading }}"
    decoding="{{ image_decoding }}"
    {% if image_fetchpriority %}fetchpriority="{{ image_fetchpriority }}"{% endif %}>
{%- endif -%}