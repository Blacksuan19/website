{%- assign tags = site.tags | sort -%}

<div class="tags-archive">
  <p class="tags-archive__intro">Browse all topics across posts and project write-ups. Each tag links to its own archive page.</p>
  <div class="tag-list tag-list--archive" aria-label="All tags">
    {%- for tag in tags -%}
      {%- assign tag_slug = tag[0] -%}
      {%- assign tag_count = tag | last | size -%}
      {%- include tag-chip.liquid tag=tag_slug count=tag_count -%}
    {%- endfor -%}
  </div>
</div>